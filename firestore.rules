rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if ownsUser(userId);
    }

    match /calculations/{docId} {
      allow read, create, update, delete: if ownsUser(resource.data.userId) || ownsUser(request.resource.data.userId);
    }

    match /fee_configs/{docId} {
      allow read, create, update, delete: if ownsUser(resource.data.userId) || ownsUser(request.resource.data.userId);
    }

    match /ads_reports/{docId} {
      allow read, create, update, delete: if ownsUser(resource.data.userId) || ownsUser(request.resource.data.userId);
    }

    match /settings/{userId} {
      allow read, create, update, delete: if ownsUser(userId);
    }
  }
}
